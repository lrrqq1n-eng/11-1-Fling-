-- إنشاء الواجهة المربعة
local screenGui = Instance.new("ScreenGui")
local mainSquare = Instance.new("Frame")
local titleLabel = Instance.new("TextLabel")
local toggleButton = Instance.new("TextButton")

screenGui.Name = "UncleBeastFling"
screenGui.Parent = game.CoreGui

mainSquare.Name = "MainSquare"
mainSquare.Parent = screenGui
mainSquare.BackgroundColor3 = Color3.fromRGB(0, 0, 130)
mainSquare.Size = UDim2.new(0, 150, 0, 150)
mainSquare.Position = UDim2.new(0.4, 0, 0.4, 0)
