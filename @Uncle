-- المتغيرات والوظائف (نفس الأصلية مع تحسين السرعة)
local active = false
local player = game.Players.LocalPlayer
local namesToFind = {"فلوس", "بات مان", "فلوس بات مان"}

local function forceEquip()
    local char = player.Character
    if not char then return end
    local toolInHand = char:FindFirstChildOfClass("Tool")
    
    if not toolInHand then
        for _, tool in pairs(player.Backpack:GetChildren()) do
            for _, name in pairs(namesToFind) do
                if tool.Name:find(name) then
                    tool.Parent = char
                    break
                end
            end
        end
    end
end

toggleButton.MouseButton1Click:Connect(function()
    active = not active
    if active then
        toggleButton.Text = "ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0) -- أخضر عند التشغيل
        
        task.spawn(function()
            while active do
                for _, target in pairs(game.Players:GetPlayers()) do
                    if not active then break end
                    if target ~= player and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                        local tRoot = target.Character.HumanoidRootPart
                        local startTick = tick()
                        local hasFlung = false

                        while active and not hasFlung and (tick() - startTick) < 20 do
                            forceEquip() 
                            
                            local char = player.Character
                            local root = char and char:FindFirstChild("HumanoidRootPart")
                            
                            if root and tRoot then
                                local offsets = {
                                    CFrame.new(0, 0, 1.5), CFrame.new(1.5, 0, 0),
                                    CFrame.new(0, 0, -1.5), CFrame.new(-1.5, 0, 0),
                                    CFrame.new(1, 0, 1), CFrame.new(-1, 0, -1)
                                }
                                
                                for _, offset in pairs(offsets) do
                                    root.CFrame = tRoot.CFrame * offset * CFrame.Angles(0, math.rad(math.random(0,360)), 0)
                                    game:GetService("RunService").Heartbeat:Wait()
                                end

                                if (tRoot.Position.Y < -50 or tRoot.Position.Y > 500 or (tRoot.Position - root.Position).Magnitude > 100) then
                                    hasFlung = true
                                end
                            else
                                player.CharacterAdded:Wait()
                                task.wait(0.2)
                                root = player.Character:WaitForChild("HumanoidRootPart")
                            end
                        end

                        if (tick() - startTick) >= 20 and not hasFlung then
                            if player.Character and player.Character:FindFirstChild("Humanoid") then
                                player.Character.Humanoid.Health = 0
                                player.CharacterAdded:Wait()
                                task.wait(0.5)
                            end
                        end
                    end
                end
                task.wait()
            end
        end)
    else
        toggleButton.Text = "OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    end
end)
